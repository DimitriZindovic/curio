# Base de données Postgres (Neon en prod) — connection string avec sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Base "shadow" utilisée par Prisma pour les migrations (dev local)
SHADOW_DATABASE_URL="postgresql://user@localhost:5432/curio_shadow"

# Clé API Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# Better Auth — secret de signature (openssl rand -base64 32) et URL de base
BETTER_AUTH_SECRET="change-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Secret protégeant l'endpoint de refresh automatique (/api/cron/refresh)
CRON_SECRET="change-me-cron-secret"
